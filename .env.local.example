# Anthropic — required for lead generation and outreach drafting
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Postgres — run `vercel env pull .env.local` after creating a Postgres database
# in the Vercel dashboard to auto-populate these
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Cron security — any random string, set this in Vercel env vars too
CRON_SECRET=your-random-secret-here
